---
import Container from "./Container.astro";
import Section from "./Section.astro";
---

<Section id="etusivu" class="surface-section" style="--surface: linear-gradient(180deg, #f7f4ef 0%, #faf9f7 100%);">
  <Container>
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-2xl text-center lg:text-left">
        
        <h1 class="max-w-xl text-4xl md:text-5xl lg:text-6xl section-title mb-6 lg:mb-7">
          Jalkojenhoitoa kotiisi
        </h1>
        <p class="mx-auto max-w-xl text-base leading-8 text-muted md:text-lg lg:mx-0 mb-9">
          Ammattitaitoista, kiireetöntä ja yksilöllistä jalkojenhoitoa asiakkaan omassa kodissa.
        </p>
        <a href="/#yhteys" class="btn-primary">Ota yhteyttä</a>
        <div class="mt-8 inline-block rounded-2xl bg-white px-5 py-4 shadow-sm">
          <h3 class="mb-2 font-semibold text-base text-text">Kotikäynnit Helsingin alueella</h3>
          <p class="text-sm text-muted leading-7">Palvelen asiakkaita kotikäynneillä Helsingissä. Hoito tapahtuu turvallisesti ja kiireettömästi asiakkaan omassa kodissa.</p>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-xl lg:ml-auto">
        <div class="absolute inset-0 -z-10 rounded-[2rem] bg-[radial-gradient(circle_at_top_left,rgba(169,196,176,0.34),transparent_42%),linear-gradient(135deg,rgba(255,255,255,0.7),rgba(247,244,239,0.7))] blur-2xl"></div>
        <div class="overflow-hidden rounded-[2rem] bg-white p-3 shadow-[0_18px_50px_rgba(17,24,39,0.08)]">
          <div class="flex min-h-[320px] items-end rounded-[1.6rem] bg-[linear-gradient(160deg,#FAF9F7_0%,#F7F4EF_58%,#E9EFE6_100%)] p-6 md:min-h-[460px] md:p-8">
            <div class="max-w-xs rounded-[1.4rem] bg-white/82 p-5 shadow-sm backdrop-blur-sm">
              <div class="mb-4 h-2 w-16 rounded-full bg-accent/70"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>