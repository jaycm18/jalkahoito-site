---
import Container from "./Container.astro";
---

<header class="sticky top-0 z-50 border-b border-black/5 bg-[rgba(250,249,247,0.78)] backdrop-blur-md">
  <Container>
    <nav class="flex items-center justify-between py-4 sm:py-5">
      <a href="/#etusivu" class="font-serif text-xl text-primary md:text-2xl">Jalka-Asema KV</a>
      <div class="flex items-center gap-4 text-sm font-medium text-muted sm:gap-5">
        <a class="hover:text-primary hover:-translate-y-px transition-all" href="/#etusivu">Etusivu</a>
        <a class="hover:text-primary hover:-translate-y-px transition-all" href="/#tietoa">Tietoa</a>
        <a class="hover:text-primary hover:-translate-y-px transition-all" href="/#palvelut">Palvelut</a>
        <a class="hover:text-primary hover:-translate-y-px transition-all" href="/#hinnasto">Hinnasto</a>
        <a class="hover:text-primary hover:-translate-y-px transition-all" href="/#yhteys">Yhteystiedot</a>
      </div>
    </nav>
  </Container>
</header>