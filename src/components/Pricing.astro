---
import Container from "./Container.astro";
import Section from "./Section.astro";

const prices = [
  { name: "Perusjalkahoito", price: "80 €" },
  { name: "Vaativa jalkahoito", price: "90 €" },
  { name: "Erityisvaativa jalkahoito", price: "105 €" },
];
---

<Section id="hinnasto" class="surface-section" style="--surface: #f2f0ea;">
  <Container>
    <div class="mx-auto max-w-3xl">
      <h2 class="section-title mb-4 text-center">Hinnasto</h2>
      <p class="mx-auto mb-10 max-w-xl text-center text-muted leading-7">
        Selkeä hinnoittelu ilman yllätyksiä.
      </p>
      <div class="space-y-3">
        {
          prices.map((item) => (
            <div class="card-elevated rounded-2xl bg-white px-6 py-5 sm:px-7 sm:py-6">
              <div class="flex items-center justify-between gap-6">
                <span class="text-base font-medium text-text">{item.name}</span>
                <span class="font-semibold text-primary">{item.price}</span>
              </div>
            </div>
          ))
        }
      </div>
      <p class="mt-6 text-center text-sm text-muted">
        Kaikki hinnat sisältävät kotikäyntimaksun ja minulla on kaikki tarvittavat välineet sekä tarvikkeet mukana. <br />
      </p>
    </div>
  </Container>
</Section>