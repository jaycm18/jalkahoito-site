---
import Container from "./Container.astro";
import Section from "./Section.astro";
---

<Section class="surface-section text-white" style="--surface: #35524a;">
  <Container>
    <div class="mx-auto max-w-3xl rounded-[1.75rem] px-4 py-2 text-center sm:px-8 sm:py-6">
      <h2 class="text-3xl md:text-4xl font-serif mb-4 text-white">
        Tarvitsetko apua jalkojen hoidossa?
      </h2>
    </div>
  </Container>
</Section>