---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
---

<BaseLayout title="Kiitos viestistä">
  <section class="py-section">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="section-title mb-4">Kiitos viestistä!</h1>
        <p class="text-muted mb-8">Viestisi on vastaanotettu. Otan sinuun yhteyttä mahdollisimman pian.</p>
        <a href="/" class="btn-light">Takaisin etusivulle</a>
      </div>
    </Container>
  </section>
</BaseLayout>
